{
  "expo": {
    "name": "ClearPayApp",
    "slug": "ClearPayApp",
    "scheme": "clearpay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./Logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./Logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.ClearPayApp",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "ClearPay uses your photo library so you can choose a profile picture."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./Logo.png",
        "backgroundColor": "#5B3FD9"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./Logo.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}
